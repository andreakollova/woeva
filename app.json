{
  "expo": {
    "name": "Woeva",
    "slug": "woeva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "woeva",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C8FF00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.woeva.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Woeva uses your location to show events near you.",
        "NSCameraUsageDescription": "Woeva uses your camera to upload event photos.",
        "NSPhotoLibraryUsageDescription": "Woeva uses your photo library to upload event photos.",
        "NSUserTrackingUsageDescription": "Woeva uses this to personalise your event feed.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C8FF00"
      },
      "package": "com.woeva.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#C8FF00"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.woeva.app",
          "enableGooglePay": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.YOUR_GOOGLE_CLIENT_ID"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8eddd0fa-6bb8-47a2-bb21-5eaa63f470a2"
      }
    }
  }
}
